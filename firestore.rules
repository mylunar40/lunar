// ═══════════════════════════════════════════════════════════════════════
//  LUNAR AI — Firestore Security Rules
//  Version: 1.0.0
//  Last updated: 2026-06-10
//
//  DEPLOY COMMAND:
//    firebase deploy --only firestore:rules
//
//  PRINCIPLE: Each user can only read and write their own data.
//  Anonymous/guest users are allowed read access to community_posts
//  but cannot write. All writes require authentication.
// ═══════════════════════════════════════════════════════════════════════

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ──────────────────────────────────────────────

    /// True when the request is from a verified, non-anonymous user.
    function isSignedIn() {
      return request.auth != null && !request.auth.token.firebase.sign_in_provider.matches('anonymous');
    }

    /// True when the requesting user owns the document (by uid field).
    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    /// True when request fields are within allowed set (no extra fields injected).
    function hasOnly(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // ── users/{uid} ───────────────────────────────────────────────────
    match /users/{uid} {
      allow read:  if isOwner(uid);
      allow create: if isOwner(uid) && isSignedIn();
      allow update: if isOwner(uid) && isSignedIn();
      allow delete: if isOwner(uid) && isSignedIn();

      // Cycle logs subcollection
      match /cycles/{cycleId} {
        allow read, write: if isOwner(uid) && isSignedIn();
      }
    }

    // ── cycles/{docId} — LEGACY top-level collection ─────────────────
    // These documents were written before subcollection migration.
    // Read allowed for own documents only. No new writes accepted here
    // (all new writes go to users/{uid}/cycles subcollection).
    match /cycles/{docId} {
      allow read:  if request.auth != null && resource.data.uid == request.auth.uid;
      allow write: if false; // Deprecated — use users/{uid}/cycles subcollection
    }

    // ── moods/{docId} ─────────────────────────────────────────────────
    match /moods/{docId} {
      allow read:   if request.auth != null && resource.data.uid == request.auth.uid;
      allow create: if isSignedIn()
                    && request.resource.data.uid == request.auth.uid
                    && request.resource.data.keys().hasAll(['uid', 'mood', 'intensity', 'createdAt']);
      allow update, delete: if isSignedIn() && resource.data.uid == request.auth.uid;
    }

    // ── journals/{docId} ─────────────────────────────────────────────
    match /journals/{docId} {
      allow read:   if request.auth != null && resource.data.uid == request.auth.uid;
      allow create: if isSignedIn()
                    && request.resource.data.uid == request.auth.uid
                    && request.resource.data.keys().hasAll(['uid', 'content', 'createdAt'])
                    && request.resource.data.content.size() <= 10000; // 10KB max
      allow update: if isSignedIn()
                    && resource.data.uid == request.auth.uid
                    && request.resource.data.content.size() <= 10000;
      allow delete: if isSignedIn() && resource.data.uid == request.auth.uid;
    }

    // ── pregnancy/{uid} ──────────────────────────────────────────────
    match /pregnancy/{uid} {
      allow read, write: if isOwner(uid) && isSignedIn();
    }

    // ── pregnancy_journals/{docId} ────────────────────────────────────
    match /pregnancy_journals/{docId} {
      allow read:   if request.auth != null && resource.data.uid == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.uid == request.auth.uid;
    }

    // ── ai_memory/{uid} ──────────────────────────────────────────────
    match /ai_memory/{uid} {
      allow read, write: if isOwner(uid) && isSignedIn();
    }

    // ── avatars/{uid} ─────────────────────────────────────────────────
    match /avatars/{uid} {
      allow read:  if isOwner(uid);
      allow write: if isOwner(uid) && isSignedIn();
    }

    // ── community_posts/{postId} ─────────────────────────────────────
    // Anyone authenticated (including guests) may read.
    // Only non-anonymous users may create.
    // Authors may update/delete their own posts.
    match /community_posts/{postId} {
      allow read: if request.auth != null;
      allow create: if isSignedIn()
                    && request.resource.data.uid == request.auth.uid
                    && request.resource.data.content.size() <= 2000; // 2KB max
      allow update: if isSignedIn()
                    && (
                      resource.data.uid == request.auth.uid
                      // Allow reaction/comment count increments by any signed-in user
                      || (request.resource.data.diff(resource.data).affectedKeys()
                          .hasOnly(['reactions', 'commentsCount', 'isReported']))
                    );
      allow delete: if isSignedIn() && resource.data.uid == request.auth.uid;
    }

    // ── community_comments/{commentId} ───────────────────────────────
    match /community_comments/{commentId} {
      allow read:   if request.auth != null;
      allow create: if isSignedIn()
                    && request.resource.data.uid == request.auth.uid
                    && request.resource.data.content.size() <= 1000;
      allow update, delete: if isSignedIn() && resource.data.uid == request.auth.uid;
    }

    // ── community_bookmarks/{uid_postId} ─────────────────────────────
    match /community_bookmarks/{bookmarkId} {
      allow read:   if request.auth != null && resource.data.uid == request.auth.uid;
      allow write:  if isSignedIn() && request.resource.data.uid == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.uid == request.auth.uid;
    }

    // ── community_reports/{reportId} ─────────────────────────────────
    match /community_reports/{reportId} {
      allow create: if isSignedIn() && request.resource.data.reportedBy == request.auth.uid;
      allow read:   if false; // Admin only (use Firebase Admin SDK / console)
      allow update, delete: if false;
    }

    // ── community/{docId} — LEGACY collection ────────────────────────
    match /community/{docId} {
      allow read:  if request.auth != null && resource.data.uid == request.auth.uid;
      allow write: if false; // Deprecated — use community_posts
    }

    // ── chatHistory/{uid} — AI conversation history ──────────────────
    match /chatHistory/{uid} {
      allow read, write: if isOwner(uid) && isSignedIn();
    }

    // ── connection_requests/{requestId} ──────────────────────────────
    // Only the sender can create. Both parties can read. Only the
    // receiver can update (accept/reject). Either party can delete.
    match /connection_requests/{requestId} {
      allow create: if isSignedIn()
                    && request.resource.data.fromUid == request.auth.uid
                    && request.resource.data.keys().hasAll([
                         'fromUid', 'toUid', 'fromPseudonym', 'toPseudonym',
                         'fromAvatarEmoji', 'fromAvatarColorHex', 'status', 'createdAt'
                       ])
                    && request.resource.data.status == 'pending'
                    && request.resource.data.fromUid != request.resource.data.toUid;
      allow read:   if isSignedIn()
                    && (resource.data.fromUid == request.auth.uid
                        || resource.data.toUid == request.auth.uid);
      // Receiver may update status (accept/reject); sender may cancel (update to rejected)
      allow update: if isSignedIn()
                    && (resource.data.toUid == request.auth.uid
                        || resource.data.fromUid == request.auth.uid)
                    && request.resource.data.diff(resource.data).affectedKeys()
                       .hasOnly(['status', 'respondedAt']);
      allow delete: if isSignedIn()
                    && (resource.data.fromUid == request.auth.uid
                        || resource.data.toUid == request.auth.uid);
    }

    // ── connections/{connectionId} ────────────────────────────────────
    // Id format: "{uid1}_{uid2}" where uid1 < uid2 alphabetically.
    // Either party may create (from acceptRequest). Either party may delete.
    match /connections/{connectionId} {
      allow read:   if isSignedIn()
                    && (resource.data.uid1 == request.auth.uid
                        || resource.data.uid2 == request.auth.uid);
      allow create: if isSignedIn()
                    && (request.resource.data.uid1 == request.auth.uid
                        || request.resource.data.uid2 == request.auth.uid)
                    && request.resource.data.keys().hasAll(['uid1', 'uid2', 'connectedAt'])
                    && request.resource.data.uid1 != request.resource.data.uid2;
      allow delete: if isSignedIn()
                    && (resource.data.uid1 == request.auth.uid
                        || resource.data.uid2 == request.auth.uid);
      allow update: if false; // Connections are immutable — disconnect = delete
    }

    // ── blocked_users/{blockedId} ─────────────────────────────────────
    // Id format: "{blockerUid}_{blockedUid}".
    // Only the blocker may create/delete. Both parties may read (to check status).
    match /blocked_users/{blockedId} {
      allow create: if isSignedIn()
                    && request.resource.data.blockerUid == request.auth.uid
                    && request.resource.data.keys().hasAll(['blockerUid', 'blockedUid', 'blockedAt'])
                    && request.resource.data.blockerUid != request.resource.data.blockedUid;
      allow read:   if isSignedIn()
                    && (resource.data.blockerUid == request.auth.uid
                        || resource.data.blockedUid == request.auth.uid);
      allow delete: if isSignedIn() && resource.data.blockerUid == request.auth.uid;
      allow update: if false; // Block records are immutable — unblock = delete
    }

    // ── Deny everything else by default ──────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
